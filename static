body{
    font-family: Arial;
    text-align:center;
}

.products{
    display:flex;
    gap:20px;
    justify-content:center;
    flex-wrap:wrap;
}

.product{
    border:1px solid #ddd;
    padding:15px;
    width:250px;
}

.product img{
    width:100%;
    height:200px;
    object-fit:cover;
}

button{
    padding:10px;
    cursor:pointer;
}
